{
    "compileOnSave": false,
    "compilerOptions": {
      "resolveJsonModule": true,
      "target": "es2020",
      "module": "commonjs",
      "skipLibCheck": true,
      "esModuleInterop": true,
      "sourceMap": true,
      "moduleResolution": "node",
      "outDir": "dist",
      "typeRoots": ["node_modules/@types"]
    },
    "include": ["typings.d.ts", "src/**/*.ts"],
    "exclude": ["node_modules"]
  }