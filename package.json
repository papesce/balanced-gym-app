{
  "name": "balanced-gym-app",
  "private": true,
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=6",
    "yarn": ">=1.21"
  },
  "author": "Pablo Pesce <papesce@gmail.com>",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npx npm-run-all --parallel dev:client dev:server",
    "dev:admin": "npx npm-run-all --parallel dev:admin:app dev:server",
    "dev:all": "npx npm-run-all --parallel dev:client dev:admin:app dev:server",
    "dev:client": "yarn workspace balanced-gym-app-client dev",
    "dev:admin:app": "yarn workspace balanced-gym-app-admin dev",
    "dev:server": "yarn workspace balanced-gym-app-server dev",
    "start": "yarn workspace balanced-gym-app-server start",
    "types": "yarn workspace balanced-gym-model types",
    "build": "yarn workspace balanced-gym-model types && npx npm-run-all --parallel build:client",
    "build:client": "yarn workspace balanced-gym-app-client build",
    "build:admin": "yarn workspace balanced-gym-app-admin build",
    "test:model": "yarn workspace balanced-gym-model test",
    "test:client": "yarn workspace balanced-gym-app-client test"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
