{
  "name": "balanced-gym-app",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "author": "Pablo Pesce <papesce@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --parallel --filter balanced-gym-app-client --filter balanced-gym-app-server run dev",
    "dev:admin": "pnpm dev:server & wait-on http://localhost:3000/spec && pnpm dev:admin:app",
    "dev:all": "pnpm dev:server & wait-on http://localhost:3000/spec && pnpm --parallel --filter balanced-gym-app-client --filter balanced-gym-app-admin run dev",
    "dev:client": "pnpm --filter balanced-gym-app-client dev",
    "dev:admin:app": "pnpm --filter balanced-gym-app-admin dev",
    "dev:server": "pnpm --filter balanced-gym-app-server dev",
    "start": "pnpm --filter balanced-gym-app-server start",
    "types": "pnpm --filter balanced-gym-model types",
    "build": "pnpm --filter balanced-gym-model types && pnpm --parallel --filter balanced-gym-app-client --filter balanced-gym-app-server run build",
    "build:client": "pnpm --filter balanced-gym-app-client build",
    "build:admin": "pnpm --filter balanced-gym-app-admin build",
    "test:model": "pnpm --filter balanced-gym-model test",
    "test:client": "pnpm --filter balanced-gym-app-client test",
    "backup": "pnpm --filter balanced-gym-app-server backup",
    "restore": "pnpm --filter balanced-gym-app-server restore",
    "set-admin": "pnpm --filter balanced-gym-app-server set-admin",
    "local-deploy": "./local-deploy.sh"
  },
  "packageManager": "pnpm@10.25.0+sha512.5e82639027af37cf832061bcc6d639c219634488e0f2baebe785028a793de7b525ffcd3f7ff574f5e9860654e098fe852ba8ac5dd5cefe1767d23a020a92f501",
  "dependencies": {
    "wait-on": "^9.0.5"
  }
}
